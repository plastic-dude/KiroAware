{
  "name": "kiroaware-mcp-server",
  "version": "1.0.0",
  "description": "KiroAware — System Context Awareness MCP Server for Kiro IDE",
  "type": "commonjs",
  "main": "dist/bridge.js",
  "bin": "dist/bridge.js",
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/bridge.js",
    "mcp": "node dist/index.js",
    "lint": "tsc --noEmit",
    "package": "pkg . --targets node22-linux-x64,node22-macos-x64,node22-win-x64 --output dist/kiroaware"
  },
  "keywords": [
    "mcp",
    "kiro",
    "system",
    "context",
    "awareness"
  ],
  "author": "David (plastic-dude)",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "systeminformation": "^5.25.11",
    "zod": "^3.25.72"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.15.44",
    "typescript": "^5.8.3"
  }
}
